[user]
    name = C. Berger
    email = 71664347+c-berger@users.noreply.github.com

[core]
    editor = nvim
    fileMode = false
    preloadindex = true
    fscache = true
    fsmonitor = true
    untrackedCache = true
    safecrlf = false
    autocrlf = input
    longpaths = true
    pager = delta

[feature]
    manyFiles = true

[index]
    version = 4

[gc]
    auto = 256
    writeCommitGraph = true

[pull]
    rebase = false

[commit]
    graph = true

[status]
    submoduleSummary = true

[diff]
    algorithm = histogram
    colorMoved = default
    renames = true

[merge]
    conflictstyle = diff3
    renames = true

[pack]
    threads = 0

[fetch]
    writeCommitGraph = true

[repack]
    writeBitmaps = true

[init]
    defaultBranch = main

[interactive]
    diffFilter = delta --color-only

[add.interactive]
    useBuiltIn = false

[delta]
    feature = catppuccin-mocha
    navigate = true
    line-numbers = true
    side-by-side = true
    dark = true

