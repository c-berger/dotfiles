[include]
    path = ~/.dotfiles/git/gitconfig

[includeIf "gitdir:C:/dev/projects/"]
    path = ~/.dotfiles/git/gitconfig_work

[core]
    editor = vim
    sshCommand = C:/windows/System32/OpenSSH/ssh.exe

[merge]
    tool = vscode

[diff]
    tool = vscode

[difftool "vscode"]
    cmd = "code --wait --diff \"$LOCAL\" \"$REMOTE\""

[mergetool "vscode"]
    cmd = "code --wait \"$MERGED\""

[difftool "sourcetree"]
    cmd = "'' "

[mergetool "sourcetree"]
    cmd = "'' "
    trustExitCode = true
    keepBackup = false

[cmder]
    status = true

[credential]
    helper = manager-core

[credential "helperselector"]
    selected = wincred

