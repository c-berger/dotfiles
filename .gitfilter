[filter "ditto"]
    clean = ./ditto/.gitfilter.sh clean
    smudge = ./ditto/.gitfilter.sh smudge
[filter "scoop"]
    clean = sed '/last_update/d'
    smudge = cat
[filter "notepad++"]
    clean = ./notepad++/.gitfilter.sh clean
    smudge = ./notepad++/.gitfilter.sh smudge
[filter "everything"]
    clean = ./everything/.gitfilter.sh clean
    smudge = ./notepad++/.gitfilter.sh smudge
[filter "userprofile"]
    smudge = perl -pe 's/\\{\\{USERPROFILE\\}\\}/$ENV{USERPROFILE}/g'
    clean = perl -pe 's/\\Q$ENV{USERPROFILE}\\E/{{USERPROFILE}}/g'
[filter "username"]
    smudge = perl -pe 's/\\{\\{USERNAME\\}\\}/$ENV{USERNAME}/g'
    clean = perl -pe 's/\\Q$ENV{USERNAME}\\E/{{USERNAME}}/g'

