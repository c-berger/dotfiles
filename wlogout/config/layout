{
    "label" : "lock",
    "action" : "hyprlock",
    "text" : "Lock (l)",
    "keybind" : "l"
}
{
    "label" : "logout",
    "action": "hyprshutdown -t 'Logout'"
    "text" : "Logout (e)",
    "keybind" : "e"
}
{
    "action": "hyprshutdown -t 'Shutting down...' --post-cmd 'systemctl poweroff'"
    "label" : "shutdown",
    "text" : "Shutdown (s)",
    "keybind" : "s"
}
{
    "label" : "reboot",
    "action": "hyprshutdown -t 'Rebooting...' --post-cmd 'systemctl reboot'"
    "text" : "Reboot (r)",
    "keybind" : "r"
}

